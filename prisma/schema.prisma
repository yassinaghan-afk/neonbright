// Neon Bright CMS — PostgreSQL schema (Prisma 7)
// Structured CMS data only. Media files stay in STORAGE_ROOT/uploads.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Portfolio ────────────────────────────────────────────────────────────────

model PortfolioCategory {
  id           String  @id
  slug         String  @unique
  title        String
  titleAccent  String  @default("")
  description  String  @default("")
  coverImage   String  @default("")
  coverAlt     String  @default("")
  heroImage    String  @default("")
  href         String  @default("")
  pageTitle    String  @default("")
  pageSubtitle String  @default("")
  enabled      Boolean @default(true)
  sortOrder    Int     @default(0)
  custom       Json?

  projects PortfolioProject[]

  @@index([sortOrder])
  @@index([enabled, sortOrder])
}

model PortfolioProject {
  id               String   @id
  categoryId       String
  slug             String
  title            String
  description      String   @default("")
  shortDescription String   @default("")
  client           String   @default("")
  city             String   @default("")
  country          String   @default("")
  year             String   @default("")
  featuredImage    String   @default("")
  coverImage       String   @default("")
  thumbnail        String   @default("")
  imageAlt         String   @default("")
  tags             String[] @default([])
  accent           String   @default("neon-pink")
  published        Boolean  @default(false)
  sortOrder        Int      @default(0)

  // Optional / brand-specific fields (preserved exactly)
  type                String?
  typeLabel           String?
  logoFile            String?
  installationType    String?
  beforeImage         String?
  afterImage          String?
  relatedProjectSlugs String[] @default([])
  technologies        String[] @default([])
  filters             String[] @default([])
  seoTitle            String?
  seoDescription      String?
  subtitle            String?

  /// Unknown/custom fields not yet promoted to columns.
  custom Json?

  category PortfolioCategory @relation(fields: [categoryId], references: [id])
  media    ProjectMedia[]

  @@unique([categoryId, slug])
  @@index([slug])
  @@index([categoryId])
  @@index([published])
  @@index([sortOrder])
  @@index([categoryId, published, sortOrder])
}

/// Ordered media entries for a project. `role` maps back to the JSON arrays:
/// image → images[], gallery → gallery[], video → videos[].
model ProjectMedia {
  id        String @id @default(cuid())
  projectId String
  role      String // "image" | "gallery" | "video"
  url       String
  sortOrder Int    @default(0)

  project PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, role, sortOrder])
  @@index([projectId, role, sortOrder])
}

// ── Homepage collections ─────────────────────────────────────────────────────

model HeroSlide {
  id        String  @id
  src       String
  alt       String  @default("")
  enabled   Boolean @default(true)
  sortOrder Int     @default(0)
  custom    Json?

  @@index([enabled, sortOrder])
}

/// Partner logos. kind: "partner" (homepage strip) | "brandsLogo" (Marques page).
model Partner {
  id        String  @id
  kind      String  @default("partner")
  name      String
  logoUrl   String  @default("")
  enabled   Boolean @default(true)
  sortOrder Int     @default(0)
  custom    Json?

  @@index([kind, enabled, sortOrder])
}

model Review {
  id        String  @id
  image     String
  enabled   Boolean @default(true)
  sortOrder Int     @default(0)
  custom    Json?

  @@index([enabled, sortOrder])
}

model Testimonial {
  id            String   @id
  quote         String
  author        String
  role          String   @default("")
  location      String   @default("")
  company       String?
  photo         String?
  rating        Int?
  galleryImages String[] @default([])
  videos        String[] @default([])
  audioFiles    String[] @default([])
  instagramUrl  String?
  linkedinUrl   String?
  websiteUrl    String?
  enabled       Boolean  @default(true)
  sortOrder     Int      @default(0)
  custom        Json?

  @@index([enabled, sortOrder])
}

model InstagramPost {
  id             String    @id
  image          String
  carouselImages String[]  @default([])
  altText        String?
  caption        String    @default("")
  instagramUrl   String    @default("")
  enabled        Boolean   @default(true)
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  custom         Json?

  @@index([enabled, sortOrder])
}

model InstagramReel {
  id           String  @id
  videoUrl     String
  thumbnail    String  @default("")
  caption      String  @default("")
  instagramUrl String  @default("")
  enabled      Boolean @default(true)
  sortOrder    Int     @default(0)
  custom       Json?

  @@index([enabled, sortOrder])
}

model Feature {
  id          String  @id
  title       String
  description String  @default("")
  icon        String  @default("")
  enabled     Boolean @default(true)
  sortOrder   Int     @default(0)
  custom      Json?

  @@index([enabled, sortOrder])
}

model Industry {
  id        String  @id
  name      String
  icon      String  @default("")
  enabled   Boolean @default(true)
  sortOrder Int     @default(0)
  custom    Json?

  @@index([enabled, sortOrder])
}

model ProcessStep {
  id          String @id
  step        String @default("")
  title       String
  description String @default("")
  sortOrder   Int    @default(0)
  custom      Json?

  @@index([sortOrder])
}

model FAQ {
  id        String  @id
  question  String
  answer    String  @default("")
  enabled   Boolean @default(true)
  sortOrder Int     @default(0)
  custom    Json?

  @@index([enabled, sortOrder])
}

model Service {
  id          String   @id
  title       String
  description String   @default("")
  icon        String   @default("")
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  custom      Json?

  @@index([enabled, sortOrder])
}

model NavigationItem {
  id        String  @id
  label     String
  href      String
  enabled   Boolean @default(true)
  sortOrder Int     @default(0)
  custom    Json?

  @@index([enabled, sortOrder])
}

// ── Singleton settings blocks ────────────────────────────────────────────────

/// Key/value JSONB store for singleton settings objects that are flexible
/// copy blocks (hero, sectionCopy, instagram settings, company, contact,
/// social, seo, heroMediaVersion, legacy projects). These do not justify
/// dedicated columns yet; each key holds ONE settings object, never the
/// whole CMS.
model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ── Revision / audit ─────────────────────────────────────────────────────────

model CmsRevision {
  id        Int      @id @default(autoincrement())
  revision  Int
  source    String // "json-import" | "admin" | "system"
  note      String   @default("")
  counts    Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
